# Skill-local fixed inputs. Runtime DB / MinIO defaults should live in
# scripts/execution_control/executor.local.env and are auto-loaded by the project runtime.
INSTALL_DIR="/path/to/mujitask"
MUJITASK_FEISHU_BASE_URL="https://ecncxlbv3k1g.feishu.cn/base/KzJXbZWunalHHVs4OkYcvk5gnxc"
MUJITASK_FEISHU_TK_SELECTION_TABLE_ID="tblpF46y6SkmVCE5"
MUJITASK_FEISHU_TK_SELECTION_VIEW_ID="vewhXPD4x1"
MUJITASK_FEISHU_TK_COMPETITOR_TABLE_ID="tblpzuTZXHtDq83t"
MUJITASK_FEISHU_TK_COMPETITOR_VIEW_ID="vewT6AtfED"
MUJITASK_FEISHU_TK_INFLUENCER_POOL_TABLE_ID="tblwLYl59TkfVFLe"
MUJITASK_FEISHU_TK_INFLUENCER_POOL_VIEW_ID="vewuKd9i6D"
MUJITASK_FEISHU_TK_INFLUENCER_OUTREACH_TABLE_ID="tblpK4zCGaaL6h6v"
MUJITASK_FEISHU_TK_INFLUENCER_OUTREACH_VIEW_ID="vewmMgDNV5"
MUJITASK_FEISHU_TK_HOT_VIDEO_TABLE_ID="tblP9S5mRrirutDT"
MUJITASK_FEISHU_TK_HOT_VIDEO_VIEW_ID="vewu7vztKp"
MUJITASK_FEISHU_ACCESS_TOKEN="replace-with-real-token"
# update-openclaw.sh preserves the keys below when the deployed skill is refreshed.
# Optional: overrides DEFAULT_PROFILE_REF in $INSTALL_DIR/.env for browser steps.
BROWSER_PROFILE_REF=""
# Optional explicit browser target for Roxy-based cookie sharing when profile resolution is unavailable:
# BROWSER_PROVIDER_NAME="roxy"
# BROWSER_PROFILE_ID=""
# BROWSER_WORKSPACE_ID=""
FASTMOSS_PHONE="replace-with-fastmoss-phone"
FASTMOSS_PASSWORD="replace-with-fastmoss-password"
INFLUENCER_POOL_FASTMOSS_PHONE_ENV="FASTMOSS_PHONE"
INFLUENCER_POOL_FASTMOSS_PASSWORD_ENV="FASTMOSS_PASSWORD"
EXECUTION_CONTROL_DB_URL=""
EXECUTION_CONTROL_ARTIFACT_ROOT=""
EXECUTION_CONTROL_ARTIFACT_BUCKET=""
EXECUTION_CONTROL_REQUESTED_BY=openclaw-skill
# Leave empty to auto-detect the latest OpenClaw delivery context from the agent session store
# and send the final Phase 1 summary back through `openclaw message send`.
# For local Feishu smoke tests, `feishu_bot_api` is usually more reliable because it uses the
# same bot credentials from ~/.openclaw/openclaw.json but skips the OpenClaw CLI hop.
NOTIFICATION_CHANNEL_CODE=""
OPENCLAW_AGENT_ID="tiktok-ops"
OPENCLAW_STATE_DIR="~/.openclaw"
# Optional explicit overrides for local testing:
# OPENCLAW_DELIVERY_CHANNEL="feishu"
# OPENCLAW_DELIVERY_TO="user:ou_xxx"
# OPENCLAW_DELIVERY_ACCOUNT_ID="default"
