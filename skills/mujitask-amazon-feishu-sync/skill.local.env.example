# Amazon OpenClaw entry configuration only. Runtime DB, Fact DB, object storage,
# browser profiles, Feishu table routes, and credentials remain in project runtime config.
INSTALL_DIR="/path/to/mujitask"
NOTIFICATION_CHANNEL_CODE="feishu_bot_api"
OPENCLAW_AGENT_ID="amazon-ops"
OPENCLAW_STATE_DIR="~/.openclaw"
OPENCLAW_DELIVERY_ACCOUNT_ID="default"

# Optional explicit target for a local smoke test. Normal OpenClaw execution discovers
# the current amazon-ops group session target and still enforces accountId=default.
# OPENCLAW_DELIVERY_CHANNEL="feishu"
# OPENCLAW_DELIVERY_TO="chat:oc_xxx"
