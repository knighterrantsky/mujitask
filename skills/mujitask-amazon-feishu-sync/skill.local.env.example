# Amazon OpenClaw entry configuration. Runtime DB, Fact DB, object storage,
# browser profiles, Feishu credentials, and access tokens remain in project runtime config.
INSTALL_DIR="/path/to/mujitask"
MUJITASK_FEISHU_AMAZON_PRODUCTS_BASE_URL="https://example.feishu.cn/base/app_xxx"
MUJITASK_FEISHU_AMAZON_PRODUCTS_TABLE_ID="tbl_xxx"
MUJITASK_FEISHU_AMAZON_PRODUCTS_VIEW_ID="vew_xxx"
NOTIFICATION_CHANNEL_CODE="feishu_bot_api"
OPENCLAW_AGENT_ID="amazon-ops"
OPENCLAW_STATE_DIR="~/.openclaw"
# Must match this client's local OpenClaw Feishu account id; the name is not fixed.
OPENCLAW_DELIVERY_ACCOUNT_ID="replace-with-local-feishu-account-id"

# Optional explicit target for a local smoke test. Normal OpenClaw execution discovers
# the current amazon-ops group session target and enforces the configured account id.
# OPENCLAW_DELIVERY_CHANNEL="feishu"
# OPENCLAW_DELIVERY_TO="chat:oc_xxx"
