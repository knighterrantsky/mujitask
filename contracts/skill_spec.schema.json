{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mujitask.local/contracts/skill_spec.schema.json",
  "title": "Mujitask Skill Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "metadata",
    "source_of_truth",
    "formal_task_codes",
    "purpose",
    "when_to_use",
    "execution_actions",
    "do_not_use",
    "inputs",
    "intents",
    "workflow",
    "intent_precedence",
    "output_format",
    "guardrails",
    "edge_cases",
    "final_checks",
    "examples",
    "negative_activation_examples"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "kind": {
      "const": "skill"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "title",
        "description",
        "short_description",
        "owner",
        "side_effects"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "short_description": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "side_effects": {
          "type": "boolean"
        }
      }
    },
    "source_of_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "business_overview",
        "requirements_index"
      ],
      "properties": {
        "business_overview": {
          "type": "string",
          "minLength": 1
        },
        "requirements_index": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "formal_task_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "purpose": {
      "$ref": "#/$defs/text_list"
    },
    "when_to_use": {
      "$ref": "#/$defs/text_list"
    },
    "execution_actions": {
      "$ref": "#/$defs/text_list"
    },
    "do_not_use": {
      "$ref": "#/$defs/text_list"
    },
    "inputs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "description"
        ],
        "properties": {
          "description": {
            "type": "string",
            "minLength": 1
          },
          "usage": {
            "type": "string",
            "minLength": 1
          },
          "extraction_rules": {
            "$ref": "#/$defs/text_list"
          },
          "extraction_examples": {
            "$ref": "#/$defs/text_list"
          },
          "defaults_by_intent": {
            "type": "object",
            "additionalProperties": {
              "type": [
                "string",
                "number",
                "boolean",
                "null"
              ]
            }
          }
        }
      }
    },
    "intents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "title",
          "description",
          "command",
          "target_tables",
          "required_inputs",
          "optional_inputs",
          "default_values",
          "side_effects"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "formal_workflow",
              "operational_sub_intent"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "business_flow_name": {
            "type": "string",
            "minLength": 1
          },
          "task_code": {
            "type": "string",
            "minLength": 1
          },
          "parent_task_code": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "minLength": 1
          },
          "source_tables": {
            "$ref": "#/$defs/text_list"
          },
          "target_tables": {
            "$ref": "#/$defs/text_list"
          },
          "trigger_mode_from_requirements": {
            "type": "string",
            "minLength": 1
          },
          "conversation_activation": {
            "type": "string",
            "minLength": 1
          },
          "source_documents": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "requirements",
              "design"
            ],
            "properties": {
              "requirements": {
                "$ref": "#/$defs/text_list"
              },
              "design": {
                "$ref": "#/$defs/text_list"
              }
            }
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "do_not_use": {
            "type": "string",
            "minLength": 1
          },
          "behavior_summary": {
            "$ref": "#/$defs/text_list"
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "required_inputs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "optional_inputs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "default_values": {
            "type": "object",
            "additionalProperties": {
              "type": [
                "string",
                "number",
                "boolean",
                "null"
              ]
            }
          },
          "side_effects": {
            "$ref": "#/$defs/text_list"
          }
        }
      }
    },
    "workflow": {
      "$ref": "#/$defs/text_list"
    },
    "intent_precedence": {
      "$ref": "#/$defs/text_list"
    },
    "output_format": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "success",
        "failure",
        "missing_input_examples"
      ],
      "properties": {
        "success": {
          "type": "string",
          "minLength": 1
        },
        "failure": {
          "type": "string",
          "minLength": 1
        },
        "missing_input_examples": {
          "$ref": "#/$defs/text_list"
        }
      }
    },
    "guardrails": {
      "$ref": "#/$defs/text_list"
    },
    "edge_cases": {
      "$ref": "#/$defs/text_list"
    },
    "final_checks": {
      "$ref": "#/$defs/text_list"
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "user",
          "intent",
          "reply"
        ],
        "properties": {
          "user": {
            "type": "string",
            "minLength": 1
          },
          "intent": {
            "type": "string",
            "minLength": 1
          },
          "inputs": {
            "type": "object",
            "additionalProperties": {
              "type": [
                "string",
                "number",
                "boolean",
                "null"
              ]
            }
          },
          "reply": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "negative_activation_examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "user",
          "reason"
        ],
        "properties": {
          "user": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "text_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
