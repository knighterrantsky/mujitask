# Copy this file to scripts/deploy/macos/deploy.local.env, then fill in the secrets.

# Required business/runtime secrets.
MUJITASK_TABLE_URL="https://your.feishu.cn/base/appXXX?table=tblXXX&view=vewXXX"
MUJITASK_FEISHU_ACCESS_TOKEN="replace-with-real-token"
MUJITASK_FASTMOSS_PHONE="replace-with-fastmoss-phone"
MUJITASK_FASTMOSS_PASSWORD="replace-with-fastmoss-password"

# Installation targets. Set these explicitly during field implementation.
MUJITASK_INSTALL_DIR="$HOME/apps/mujitask"
# Safety valve for field upgrades into a non-empty directory that was not created by this deploy script.
# Leave disabled unless you have inspected the target directory.
MUJITASK_ALLOW_NONEMPTY_INSTALL_DIR="0"
# Set this to the skills root watched by the target agent.
# OpenClaw example: "$HOME/.openclaw/workspace/skills"
# Hermes example: set this to the Hermes agent skills directory used on that machine.
MUJITASK_SKILLS_DIR="$HOME/.mujitask/skills"
MUJITASK_AGENT_TYPE="generic"

# Browser and notification defaults.
MUJITASK_BROWSER_PROFILE_REF="roxy-tiktok"
MUJITASK_NOTIFICATION_CHANNEL_CODE="feishu_bot_api"

# Optional OpenClaw-compatible delivery context. Leave these as-is for non-OpenClaw agents.
MUJITASK_OPENCLAW_AGENT_ID="tiktok-ops"
MUJITASK_OPENCLAW_STATE_DIR="$HOME/.openclaw"

# Local runtime mode. "native" installs/starts local Postgres and MinIO on macOS.
# Homebrew must be installed. deploy.sh will install missing postgresql@17/minio formulas.
MUJITASK_RUNTIME_MODE="native"

# Local Postgres exposed only on localhost.
MUJITASK_POSTGRES_FORMULA="postgresql@17"
MUJITASK_POSTGRES_PORT="5432"
MUJITASK_POSTGRES_DB="automation_business_scaffold"
# Leave empty to use the current macOS user and a local Unix socket.
MUJITASK_POSTGRES_USER=""
MUJITASK_POSTGRES_SOCKET_DIR="/tmp"

# Local MinIO exposed only on localhost.
MUJITASK_MINIO_BIND="127.0.0.1"
MUJITASK_MINIO_PORT="9000"
MUJITASK_MINIO_CONSOLE_BIND="127.0.0.1"
MUJITASK_MINIO_CONSOLE_PORT="9001"
MUJITASK_MINIO_ROOT_USER="minioadmin"
MUJITASK_MINIO_ROOT_PASSWORD="minioadmin"
MUJITASK_MINIO_BUCKET="automation-business-scaffold"
MUJITASK_MINIO_DATA_DIR="runtime/minio/data"
MUJITASK_ARTIFACT_OBJECT_PREFIX="phase2/local"

# Advanced overrides. Usually leave these empty for one-click local deployment.
# MUJITASK_DB_URL="postgresql+psycopg://postgres:postgres@127.0.0.1:5432/automation_business_scaffold"
# MUJITASK_DB_PATH=""
# MUJITASK_ARTIFACT_ROOT="$PWD/runtime/execution_control/object_store"
# MUJITASK_ARTIFACT_STORE_PROVIDER="minio"
