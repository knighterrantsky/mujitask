# Copy this file to scripts/deploy/macos/deploy.local.env, fill in the secrets,
# then run: chmod 600 scripts/deploy/macos/deploy.local.env

# Required business/runtime secrets.
# Feishu business table routes. Config keys use English aliases only.
MUJITASK_FEISHU_BASE_URL="https://ecncxlbv3k1g.feishu.cn/base/KzJXbZWunalHHVs4OkYcvk5gnxc"
MUJITASK_FEISHU_TK_SELECTION_TABLE_ID="tblpF46y6SkmVCE5"
MUJITASK_FEISHU_TK_SELECTION_VIEW_ID="vewhXPD4x1"
MUJITASK_FEISHU_TK_COMPETITOR_TABLE_ID="tblpzuTZXHtDq83t"
MUJITASK_FEISHU_TK_COMPETITOR_VIEW_ID="vewT6AtfED"
MUJITASK_FEISHU_TK_INFLUENCER_POOL_TABLE_ID="tblwLYl59TkfVFLe"
MUJITASK_FEISHU_TK_INFLUENCER_POOL_VIEW_ID="vewuKd9i6D"
MUJITASK_FEISHU_TK_INFLUENCER_OUTREACH_TABLE_ID="tblpK4zCGaaL6h6v"
MUJITASK_FEISHU_TK_INFLUENCER_OUTREACH_VIEW_ID="vewmMgDNV5"
MUJITASK_FEISHU_TK_HOT_VIDEO_TABLE_ID="tblP9S5mRrirutDT"
MUJITASK_FEISHU_TK_HOT_VIDEO_VIEW_ID="vewu7vztKp"
MUJITASK_FEISHU_AMAZON_PRODUCTS_TABLE_ID="replace-with-amazon-products-table-id"
MUJITASK_FEISHU_AMAZON_PRODUCTS_VIEW_ID="replace-with-amazon-products-view-id"
MUJITASK_FEISHU_ACCESS_TOKEN="replace-with-real-token"
MUJITASK_FASTMOSS_PHONE="replace-with-fastmoss-phone"
MUJITASK_FASTMOSS_PASSWORD="replace-with-fastmoss-password"

# Installation targets. Set these explicitly during field implementation.
MUJITASK_INSTALL_DIR="$HOME/apps/mujitask"
# Safety valve for field upgrades into a non-empty directory that was not created by this deploy script.
# Leave disabled unless you have inspected the target directory.
MUJITASK_ALLOW_NONEMPTY_INSTALL_DIR="0"
# Set this to the skills root watched by the target agent.
# OpenClaw example: "$HOME/.openclaw/workspace/skills"
# Hermes example: set this to the Hermes agent skills directory used on that machine.
MUJITASK_SKILLS_DIR="$HOME/.mujitask/skills"
MUJITASK_AGENT_TYPE="generic"

# Browser and notification defaults.
MUJITASK_BROWSER_PROFILE_REF="roxy-tiktok"
MUJITASK_AMAZON_US_BROWSER_PROFILE_REF="replace-with-amazon-us-browser-profile"
MUJITASK_NOTIFICATION_CHANNEL_CODE="feishu_bot_api"

# Optional OpenClaw-compatible delivery context. Leave these as-is for non-OpenClaw agents.
MUJITASK_OPENCLAW_AGENT_ID="tiktok-ops"
MUJITASK_OPENCLAW_STATE_DIR="$HOME/.openclaw"

# Local runtime mode. "native" installs/starts local Postgres and MinIO on macOS.
# Homebrew must be installed. deploy.sh will install missing postgresql@17/minio formulas.
MUJITASK_RUNTIME_MODE="native"

# Local Postgres exposed only on localhost.
MUJITASK_POSTGRES_FORMULA="postgresql@17"
MUJITASK_POSTGRES_PORT="5432"
MUJITASK_POSTGRES_DB="automation_business_scaffold"
# Existing Runtime account used by the current Runtime/TikTok schema bootstrap path.
MUJITASK_POSTGRES_USER="mujitask"
MUJITASK_POSTGRES_PASSWORD="mujitask"
# Dedicated Fact worker account. Native deployment creates or updates this login,
# grants only governed Fact-table DML/version SELECT, and keeps migration credentials separate.
MUJITASK_FACT_RUNTIME_ROLE="mujitask_fact_runtime"
MUJITASK_FACT_RUNTIME_PASSWORD="replace-with-fact-runtime-password"
# Admin account used by deploy.sh for local database setup and Amazon Fact migrations.
# It must differ from the Fact worker role.
# Leave empty to use the current macOS user.
MUJITASK_POSTGRES_ADMIN_USER=""
# Admin socket directory used only for local bootstrap. Runtime daemons use TCP localhost by default.
MUJITASK_POSTGRES_SOCKET_DIR="/tmp"

# Local MinIO exposed only on localhost.
MUJITASK_MINIO_BIND="127.0.0.1"
MUJITASK_MINIO_PORT="9000"
MUJITASK_MINIO_CONSOLE_BIND="127.0.0.1"
MUJITASK_MINIO_CONSOLE_PORT="9001"
MUJITASK_MINIO_ROOT_USER="minioadmin"
MUJITASK_MINIO_ROOT_PASSWORD="minioadmin"
MUJITASK_MINIO_BUCKET="automation-business-scaffold"
MUJITASK_MINIO_DATA_DIR="runtime/minio/data"
MUJITASK_ARTIFACT_OBJECT_PREFIX="mujitask/local"

# Advanced overrides. Usually leave these empty for one-click local deployment.
# MUJITASK_DB_URL="postgresql+psycopg://mujitask:mujitask@127.0.0.1:5432/automation_business_scaffold"
# External mode requires a separate Runtime migration URL and both Fact URLs below
# in addition to MUJITASK_DB_URL. Migration URLs are never copied to executor.local.env
# or launchd plists. The Fact migration URL is copied only to
# runtime/deployment/migration.local.env (mode 600), never to executor.local.env or launchd plists.
# MUJITASK_RUNTIME_MIGRATION_DB_URL="postgresql+psycopg://runtime_migration:password@127.0.0.1:5432/automation_business_scaffold"
# MUJITASK_FACT_DB_URL="postgresql+psycopg://mujitask_fact_runtime:password@127.0.0.1:5432/automation_business_scaffold"
# MUJITASK_FACT_MIGRATION_DB_URL="postgresql+psycopg://mujitask_migration:password@127.0.0.1:5432/automation_business_scaffold"
# MUJITASK_ARTIFACT_ROOT="$PWD/runtime/execution_control/object_store"
# MUJITASK_ARTIFACT_STORE_PROVIDER="minio"
