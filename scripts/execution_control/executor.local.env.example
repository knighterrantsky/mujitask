# Project-level runtime config. This file is auto-loaded by CLI / daemon / pytest / Alembic.
BUSINESS_EXECUTION_CONTROL_DB_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/automation_business_scaffold
# Dedicated test DB. pytest prefers this over BUSINESS_EXECUTION_CONTROL_DB_URL so
# DB-backed regression tests do not share state with the runtime database.
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/automation_business_scaffold_test
BUSINESS_EXECUTION_CONTROL_ARTIFACT_ROOT=runtime/execution_control/object_store
BUSINESS_EXECUTION_CONTROL_ARTIFACT_BUCKET=automation-business-scaffold
